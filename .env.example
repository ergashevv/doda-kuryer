# Telegram — tokenni @BotFather dan oling; kodga yozmang
BOT_TOKEN=

# PostgreSQL
# Lokal (docker compose bilan):
# DATABASE_URL=postgresql+asyncpg://doda:doda@127.0.0.1:5432/doda
#
# Railway:
# 1) Loyihaga "PostgreSQL" qo'shing, keyin bot servisingizda Variables ichida
#    DATABASE_URL ni Postgres servisidan oling (Connect yoki Reference Variable:
#    ${{ Postgres.DATABASE_URL }} yoki ${{ PGHOST }} bilan to'liq URL).
# 2) docker-compose dagi @postgres yoki localhost URL ni productionga qo'ymang —
#    "No address associated with hostname" xatosi shundan chiqadi.
# 3) Kerak bo'lsa URL oxiriga qo'shing: ?sslmode=require
DATABASE_URL=postgresql+asyncpg://doda:doda@127.0.0.1:5432/doda

# Yuklangan fayllar — lokalda ./uploads; Railway’da Volume mount: /data va STORAGE_PATH=/data/uploads
STORAGE_PATH=./uploads

# Ixtiyoriy: webhook uchun (polling ishlatilsa bo'sh qoldiring)
WEBHOOK_URL=
