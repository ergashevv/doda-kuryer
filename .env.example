# Telegram — tokenni @BotFather dan oling; kodga yozmang
BOT_TOKEN=

# PostgreSQL (Node `pg` — `postgresql://` yoki `postgres://`)
# Lokal (docker compose bilan):
# DATABASE_URL=postgresql://doda:doda@127.0.0.1:5432/doda
#
# Railway / Neon:
# 1) Variables ichida to‘liq URL (Connect tab).
# 2) docker-compose dagi @postgres yoki localhost URL ni productionga qo‘ymang —
#    "No address associated with hostname" xatosi shundan chiqadi.
# 3) Neon: odatda `?sslmode=require` (yoki hostda SSL talab qilinadi).
DATABASE_URL=postgresql://doda:doda@127.0.0.1:5432/doda

# Yuklangan fayllar — lokalda ./uploads; Railway’da Volume mount: /data va STORAGE_PATH=/data/uploads
STORAGE_PATH=./uploads

# Telegram guruh (ID) — yig‘ilgan hujjatlar va profil xabarlari; bot guruhda xabar yubora olishi kerak
DOCS_GROUP_ID=-5228208474

# Ixtiyoriy: Neon/Railway da SSL ni majburan yoqish (odatda URL yetarli)
# DATABASE_SSL=true

# --- Next.js dashboard (web/) — bot bilan bir xil DATABASE_URL
# DASHBOARD_API_KEY=uzun-tasodifiy-kalit   # API: Bearer yoki web kirish paroli (API_KEY bo‘lsa)
# DASHBOARD_PASSWORD=admin-parol           # Faqat web login (ixtiyoriy; bo‘lmasa API_KEY ishlatiladi)

# --- Railway (loyiha → servis → Variables) — .env fayl Railway’da bo‘lmaydi, shu kalitlar qo‘yiladi
#
# Majburiy:
#   BOT_TOKEN=<@BotFather dan>
#   DATABASE_URL=<Postgres plugin: “Variable Reference” → ${{ Postgres.DATABASE_URL }} yoki Connect URL>
#   STORAGE_PATH=/data/uploads
#   DOCS_GROUP_ID=-5228208474
#
# Postgres plugin qo‘shilgan bo‘lsa, DATABASE_URL ni qo‘lda yozmasdan
# “New Variable” → Reference → Postgres → DATABASE_URL tanlang.
#
# Yuklamalar diskda qolishi uchun: servis → Settings → Volumes → mount path: /data
# (Dockerfile STORAGE_PATH=/data/uploads bilan mos; bo‘lmasa restartda fayllar yo‘qoladi)
#
# Ixtiyoriy (odatda kerak emas — URL da ssl bo‘lsa yetadi):
#   DATABASE_SSL=true
