# Telegram — tokenni @BotFather dan oling; kodga yozmang
BOT_TOKEN=

# PostgreSQL
# Lokal (docker compose bilan): quyidagi satrni ishlating
# DATABASE_URL=postgresql+asyncpg://doda:doda@127.0.0.1:5432/doda
# Railway: Variables dan kelgan URL (kerak bo'lsa sslmode qo'shing)
DATABASE_URL=postgresql+asyncpg://doda:doda@127.0.0.1:5432/doda

# Yuklangan fayllar — lokalda ./uploads; Railway’da Volume mount: /data va STORAGE_PATH=/data/uploads
STORAGE_PATH=./uploads

# Ixtiyoriy: webhook uchun (polling ishlatilsa bo'sh qoldiring)
WEBHOOK_URL=
