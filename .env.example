# Telegram — tokenni @BotFather dan oling; kodga yozmang
BOT_TOKEN=

# PostgreSQL (Node `pg` — `postgresql://` yoki `postgres://`)
# Lokal (docker compose bilan):
# DATABASE_URL=postgresql://doda:doda@127.0.0.1:5432/doda
#
# Railway / Neon:
# 1) Variables ichida to‘liq URL (Connect tab).
# 2) docker-compose dagi @postgres yoki localhost URL ni productionga qo‘ymang —
#    "No address associated with hostname" xatosi shundan chiqadi.
# 3) Neon: odatda `?sslmode=require` (yoki hostda SSL talab qilinadi).
DATABASE_URL=postgresql://doda:doda@127.0.0.1:5432/doda

# Yuklangan fayllar — lokalda ./uploads; Railway’da Volume mount: /data va STORAGE_PATH=/data/uploads
STORAGE_PATH=./uploads

# Ixtiyoriy: Neon/Railway da SSL ni majburan yoqish (odatda URL yetarli)
# DATABASE_SSL=true
